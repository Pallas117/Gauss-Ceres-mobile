# ────────────────────────────────────────────────────────────────────────────
# Project Gauss: Mission HUD — Environment Configuration
# ────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# All variables prefixed with EXPO_PUBLIC_ are accessible in the client.
#
# IMPORTANT: Never commit .env to version control. It's already in .gitignore.
#
# ────────────────────────────────────────────────────────────────────────────

# ─── OAuth Configuration ─────────────────────────────────────────────────────
# Manus OAuth SSO for user authentication
# Get these values from your Manus OAuth app registration

EXPO_PUBLIC_OAUTH_PORTAL_URL=https://oauth.example.com
EXPO_PUBLIC_OAUTH_SERVER_URL=https://api.example.com
EXPO_PUBLIC_APP_ID=your_app_id_here
EXPO_PUBLIC_OWNER_OPEN_ID=your_owner_openid_here
EXPO_PUBLIC_OWNER_NAME=Your Name

# ─── API Configuration ───────────────────────────────────────────────────────
# Backend API base URL
# - Development: http://localhost:3000
# - Production: https://api.yourproject.com
# - Sandboxed: auto-derived from hostname (e.g., 3000-sandbox.region.domain)

EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ─── Database Configuration ──────────────────────────────────────────────────
# MySQL connection string
# Format: mysql://username:password@host:port/database
#
# Example (local):
#   DATABASE_URL=mysql://root:password@localhost:3306/gauss_hud
#
# Example (production):
#   DATABASE_URL=mysql://user:pass@db.example.com:3306/gauss_hud_prod

DATABASE_URL=mysql://root:password@localhost:3306/gauss_hud

# ─── Storage Configuration ───────────────────────────────────────────────────
# Manus Forge API for file storage (S3-compatible)
# Get these from your Manus Forge dashboard

BUILT_IN_FORGE_API_URL=https://storage.example.com
BUILT_IN_FORGE_API_KEY=sk_your_api_key_here

# ─── Development Configuration ───────────────────────────────────────────────
# Metro bundler port (default: 8081)
# EXPO_PORT=8081

# Node environment (development | production)
# NODE_ENV=development

# ─── Optional: Server Configuration ──────────────────────────────────────────
# Uncomment if you need to override default server settings

# Server port (default: 3000)
# PORT=3000

# Server host (default: 0.0.0.0)
# HOST=0.0.0.0

# Enable debug logging
# DEBUG=true

# ─── Optional: External API Keys ─────────────────────────────────────────────
# These are not required — the app fetches public data from CelesTrak and NOAA

# CelesTrak TLE feeds (no API key required — public)
# CELESTRAK_API_URL=https://celestrak.org/NORAD/elements/gp.php

# NOAA SWPC (no API key required — public)
# NOAA_SWPC_API_URL=https://services.swpc.noaa.gov

# ─── Optional: Feature Flags ─────────────────────────────────────────────────
# Uncomment to enable experimental features

# Enable offline mode (not yet implemented)
# EXPO_PUBLIC_ENABLE_OFFLINE=true

# Enable real-time WebSocket streaming (not yet implemented)
# EXPO_PUBLIC_ENABLE_WEBSOCKET=true

# ────────────────────────────────────────────────────────────────────────────
# END OF CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────
